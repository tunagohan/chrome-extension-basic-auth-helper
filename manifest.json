{
  "manifest_version": 3,
  "name": "Basic Auth Helper",
  "version": "1.0.0",
  "description": "URL正規表現に応じてBasic認証を自動入力する",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html"
}
