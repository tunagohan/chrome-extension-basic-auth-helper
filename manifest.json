{
  "manifest_version": 3,
  "name": "Basic Auth Helper",
  "version": "1.1.0",
  "description": "複数URL指定に応じてBasic認証を自動入力するChrome拡張",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html"
}
